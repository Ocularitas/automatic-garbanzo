# Database
DATABASE_URL=postgresql+psycopg://contract:contract@localhost:5432/contract_intel

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# Voyage embeddings
# Fixed for the corpus. Changing this means re-embedding everything.
VOYAGE_API_KEY=pa-...
VOYAGE_EMBEDDING_MODEL=voyage-3-large
VOYAGE_EMBEDDING_DIMENSIONS=1024

# Ingestion
WATCH_FOLDER=./data/watch
RULES_DIR=./rules

# Demo identity (swap for real auth later)
DEMO_USER_ID=demo-user
DEMO_GROUP_ID=demo-group

# MCP query server
QUERY_MCP_HOST=0.0.0.0
QUERY_MCP_PORT=8765
QUERY_MCP_BEARER_TOKEN=demo-token-change-me
