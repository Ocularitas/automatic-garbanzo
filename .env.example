# Database
DATABASE_URL=postgresql+psycopg://contract:contract@localhost:5432/contract_intel

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# Voyage embeddings
# Fixed for the corpus. Changing this means re-embedding everything.
VOYAGE_API_KEY=pa-...
VOYAGE_EMBEDDING_MODEL=voyage-3-large
VOYAGE_EMBEDDING_DIMENSIONS=1024

# Ingestion
WATCH_FOLDER=./data/watch
RULES_DIR=./rules

# Demo identity (swap for real auth later)
DEMO_USER_ID=demo-user
DEMO_GROUP_ID=demo-group

# MCP query server
QUERY_MCP_HOST=0.0.0.0
QUERY_MCP_PORT=8765
QUERY_MCP_BEARER_TOKEN=demo-token-change-me

# Public base URL the deployment is reachable on, including the URL-embedded
# bearer token. The MCP server uses this to construct clickable `document_url`
# values in tool responses. Leave empty for local dev (URLs are then omitted).
# Example for the Azure deployment:
#   https://cipoc-abc123.uksouth.cloudapp.azure.com/<bearer-token>
PUBLIC_BASE_URL=

# OAuth / Entra production hooks. Leave all empty for POC mode (Caddy
# URL-token is the auth gate). Set all three (jwks_uri + issuer + audience)
# to enable JWT validation in the MCP server and expose the
# /.well-known/oauth-protected-resource discovery endpoint per RFC 9728.
#
# Typical Entra values (replace <tenant-id> with the ABP tenant GUID):
#   MCP_OAUTH_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
#   MCP_OAUTH_JWKS_URI=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
#   MCP_OAUTH_AUDIENCE=api://contract-intel-mcp
#   MCP_OAUTH_REQUIRED_SCOPES=corpus.read
MCP_OAUTH_JWKS_URI=
MCP_OAUTH_ISSUER=
MCP_OAUTH_AUDIENCE=
MCP_OAUTH_REQUIRED_SCOPES=

# Logging. Empty / "console" for dev (human-readable), "json" for production
# (one structured JSON object per line, ready for Application Insights /
# Log Analytics / any aggregator). LOG_LEVEL defaults to INFO.
LOG_FORMAT=
LOG_LEVEL=
